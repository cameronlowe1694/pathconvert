# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_products,read_themes,read_content,write_script_tags,read_locations

# App Configuration
APP_URL=https://your-app-url.com
HOST=your-app-url.com
PORT=3000
NODE_ENV=development

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=text-embedding-3-small
GPT_MODEL=gpt-3.5-turbo
EMBEDDING_DIMENSIONS=1536

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/pathconvert
PGHOST=localhost
PGPORT=5432
PGDATABASE=pathconvert
PGUSER=your_db_user
PGPASSWORD=your_db_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# App Settings (matching Colab workflow)
MAX_RECOMMENDATIONS=7
MIN_SIMILARITY_THRESHOLD=0.85
CACHE_TTL=3600
ANALYSIS_SCHEDULE=0 2 * * 0

# Session Configuration
SESSION_SECRET=your_session_secret_here
